# =========== RCA - Relatorio de Coletas e Analises ============
# Dockerfile.als — container unico (backend Express + frontend estatico)
# =============================================================
#
# Build context: pasta als/ (um nivel acima de docker/).
#
# O servidor Express serve tanto a API (/api/*) quanto o frontend
# estatico (../frontend/). Container unico = simples de operar.

FROM node:18-alpine AS base

LABEL org.opencontainers.image.title="rca-dashboard"
LABEL org.opencontainers.image.description="RCA Analise de Lubrificantes S360 — dashboard de analises quimicas"

ENV NODE_ENV=production \
    TZ=America/Recife \
    NPM_CONFIG_LOGLEVEL=warn

WORKDIR /app

# -------- Timezone --------
RUN apk add --no-cache tzdata curl \
    && cp /usr/share/zoneinfo/$TZ /etc/localtime \
    && echo "$TZ" > /etc/timezone

# -------- Dependencias Node --------
COPY backend/package.json backend/package-lock.json* /app/backend/
RUN cd /app/backend && \
    if [ -f package-lock.json ]; then \
        npm ci --omit=dev; \
    else \
        npm install --omit=dev; \
    fi

# -------- Codigo da aplicacao --------
COPY backend/server.js  /app/backend/server.js
COPY backend/db.js      /app/backend/db.js
COPY backend/queries.js /app/backend/queries.js
COPY frontend/          /app/frontend/

# -------- Usuario nao-root --------
RUN chown -R node:node /app
USER node

EXPOSE 3031

HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 \
    CMD curl -fsS http://127.0.0.1:3031/healthz || exit 1

CMD ["node", "backend/server.js"]
