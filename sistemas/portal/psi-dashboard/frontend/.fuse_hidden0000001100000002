<script id="psi-asset-restore-script">
(function(){
  function reviveMakeVideo(){
    const v=document.getElementById('makeAutomationVideo');
    if(!v) return;
    try{
      v.muted=true;
      v.loop=true;
      v.playsInline=true;
      v.removeAttribute('controls');
      v.style.opacity='1';
      v.style.visibility='visible';
      const p=v.play();
      if(p && typeof p.catch==='function') p.catch(()=>{});
    }catch(e){}
  }
  document.addEventListener('DOMContentLoaded',()=>{
    reviveMakeVideo();
    setTimeout(reviveMakeVideo,350);
    setTimeout(reviveMakeVideo,1200);
  });
  document.addEventListener('visibilitychange',()=>{ if(!document.hidden) reviveMakeVideo(); });
  document.addEventListener('click',reviveMakeVideo,{passive:true});
  window.addEventListener('scroll',reviveMakeVideo,{passive:true});
})();
</script>

