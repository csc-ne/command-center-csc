# ===================================================================
# .env.example — Template do arquivo central C:\env\.env
# ===================================================================
# Este arquivo NAO carrega segredos reais. Ele documenta QUAIS chaves
# cada sistema espera. Para uso real, preencha com valores validos e
# salve como C:\env\.env na maquina (Windows Server ou seu tester).
#
# TODOS os sistemas leem daqui via:
#   - docker-compose: env_file: - C:/env/.env
#   - codigo Python:  load_dotenv(r"C:\env\.env") no Windows
#   - codigo Node:    dotenv.config({ path: "C:\\env\\.env" }) no Windows
#     (dentro dos containers Linux, o path resolve para /app/.env que
#      e o bind mount desse mesmo arquivo)
# ===================================================================

# -- Timezone (usado por todos) --
TZ=America/Recife


# ==========================================================
# PORTAL / COMMAND CENTER
# ==========================================================
DB_HOST=192.168.0.106
DB_PORT=5432
DB_NAME=csc_veneza
DB_USER=henrique
DB_PASSWORD=
DB_SCHEMA=command_center

PORTAL_BACKEND_PORT=4000
PORTAL_JWT_SECRET=
PORTAL_ADMIN_KEY=

PORTAL_FRONTEND_PORT=4001
PORTAL_FRONTEND_URL=http://192.168.0.106:4001
PORTAL_BACKEND_URL=http://192.168.0.106:4000
COMMAND_CENTER_PORT=4001

# SMTP Office365 via OAuth2 (App Registration no Entra ID)
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=csc.noreply@venezanet.com
SMTP_FROM=csc.noreply@venezanet.com
ADMIN_EMAIL=csc.ne@venezanet.com

AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

COOKIE_SECURE=false


# ==========================================================
# RTS — Real Time Support
# ==========================================================

# John Deere OAuth2
clientId=
clientSecret=

# MySQL legado (Python + Node.js)
USERDB=
PSS=
IPDESKTOPDB=192.168.0.106
USERNAME_DB=
PASSWORD_DB=
HOST_DB=192.168.0.106
SCHEMA_DB=bancovz
TABLE_RTDB=mensagens_rtdb
TABLE_ALERTS=alertas

# PostgreSQL (RTS + RDA)
PG_HOST=192.168.0.106
PG_PORT=5432
PG_DB=csc_veneza
PG_USER=henrique
PG_PASS=

# Firebase config
UID=fortuna-major
SERVICE_ACCOUNT=serviceAccount
DATABASE_URL=https://rts-real-time-support-6ec6b-default-rtdb.firebaseio.com/

# Firebase service account (extraido do RTS/create_sa.py)
# private_key com \n literais (formato JSON escapado)
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=
FIREBASE_CLIENT_ID=

# WhatsApp Business (Meta) — TKWPP se auto-renova pelo WppTokenManager
TKWPP=
MEDIAIDWPP=
MEDIAIDEXP=
PHONE_NUMBER_ID=

SESSION_SECRET=

APP_ID=
APP_SECRET=
WPP_ACCOUNT_ID=
REFRESH_TOKEN=

# Emails admin RTS (CSV, sem espacos) — controla acesso a modo WPP e relatorios
RTS_WPP_ADMIN_EMAILS=henrique.albuquerque@venezanet.com,iremar.barros@venezanet.com


# ==========================================================
# RTA — Real Time Alert
# ==========================================================
RTA_PG_HOST=192.168.0.106
RTA_PG_PORT=5432
RTA_PG_DATABASE=csc_veneza
RTA_PG_USER=henrique
RTA_PG_PASSWORD=
RTA_PORT=3021
RTA_CORS_ORIGIN=*
RTA_AUTH_SECRET=
RTS_DASHBOARD_URL=http://192.168.0.106:8080


# ==========================================================
# RDA — Relatorios de Desempenho Automaticos
# ==========================================================
# PG_HOST/PORT/DB/USER/PASS ja declarados no bloco RTS.
RDA_FRONTEND_PORT=5050
RDA_BACKEND_PORT=5051
RDA_BACKEND_URL=http://rda-backend:5051
RDA_CORS_ORIGIN=*
COMMAND_CENTER_URL=

# Batch mensal (dia 01). Formato: Estado|ID_JD|Nome do Cliente;...
RDA_BATCH_CLIENTES=
RDA_BATCH_IDS=

RDA_AUTH_SECRET=


# ==========================================================
# RCA — Relatorio de Coletas e Analises
# ==========================================================
RCA_PG_HOST=192.168.0.106
RCA_PG_PORT=5432
RCA_PG_DATABASE=csc_veneza
RCA_PG_USER=henrique
