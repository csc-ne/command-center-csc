# ===================================================================
# .env.example — Template do arquivo central C:\env\.env
# ===================================================================
# Este arquivo NAO carrega segredos reais. Documenta as chaves que cada
# sistema espera. Preencha com valores validos e salve como
# C:\env\.env na maquina de deploy (Windows Server ou tester Windows).
#
# TODOS os sistemas leem daqui via:
#   - docker-compose: env_file: - C:/env/.env
#   - codigo Python:  load_dotenv(r"C:\env\.env") no Windows
#   - codigo Node:    dotenv.config({ path: "C:\\env\\.env" }) no Windows
#     (dentro dos containers Linux, o path resolve para /app/.env
#      via bind mount definido no docker-compose)
# ===================================================================


# -- Timezone (usado por todos os containers) --
TZ=


# ==========================================================
# PORTAL / COMMAND CENTER
# ==========================================================

# -- PostgreSQL de PRODUCAO (host da VM) --
DB_HOST=
DB_PORT=
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_SCHEMA=

# -- Backend --
PORTAL_BACKEND_PORT=
PORTAL_JWT_SECRET=
PORTAL_ADMIN_KEY=

# -- Frontend --
PORTAL_FRONTEND_PORT=
PORTAL_FRONTEND_URL=
PORTAL_BACKEND_URL=
COMMAND_CENTER_PORT=

# -- SMTP Office365 via OAuth2 (Azure App Registration) --
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_FROM=
ADMIN_EMAIL=

# -- Azure / Entra ID (App Registration com SMTP.SendAsApp) --
# Rotacione AZURE_CLIENT_SECRET periodicamente (client secrets expiram)
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# -- Cookie de sessao (false=HTTP, true=HTTPS) --
COOKIE_SECURE=


# ==========================================================
# RTS — Real Time Support
# ==========================================================

# -- John Deere OAuth2 --
clientId=
clientSecret=

# -- MySQL legado (Python + Node.js) — em descontinuacao --
USERDB=
PSS=
IPDESKTOPDB=
USERNAME_DB=
PASSWORD_DB=
HOST_DB=
SCHEMA_DB=
TABLE_RTDB=
TABLE_ALERTS=

# -- PostgreSQL (RTS + tambem lido por RDA) --
PG_HOST=
PG_PORT=
PG_DB=
PG_USER=
PG_PASS=

# -- Firebase Realtime Database --
UID=
SERVICE_ACCOUNT=
DATABASE_URL=

# -- Firebase Service Account (gerado por sistemas/rts/create_sa.py) --
# private_key com \n literais (formato JSON escapado)
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=
FIREBASE_CLIENT_ID=

# -- WhatsApp Business (Meta) — TKWPP se auto-renova pelo WppTokenManager --
TKWPP=
MEDIAIDWPP=
MEDIAIDEXP=
PHONE_NUMBER_ID=

SESSION_SECRET=

APP_ID=
APP_SECRET=
WPP_ACCOUNT_ID=
REFRESH_TOKEN=

# -- Emails admin do RTS (CSV, sem espacos) — modo WPP + relatorios globais --
RTS_WPP_ADMIN_EMAILS=


# ==========================================================
# RTA — Real Time Alert
# ==========================================================
RTA_PG_HOST=
RTA_PG_PORT=
RTA_PG_DATABASE=
RTA_PG_USER=
RTA_PG_PASSWORD=
RTA_PORT=
RTA_CORS_ORIGIN=
RTA_AUTH_SECRET=
RTS_DASHBOARD_URL=


# ==========================================================
# RDA — Relatorios de Desempenho Automaticos
# ==========================================================
# PG_HOST/PORT/DB/USER/PASS ja declarados no bloco RTS
RDA_FRONTEND_PORT=
RDA_BACKEND_PORT=
RDA_BACKEND_URL=
RDA_CORS_ORIGIN=
COMMAND_CENTER_URL=

# -- Batch mensal (dia 01). Formato: Estado|ID_JD|Nome do Cliente;... --
RDA_BATCH_CLIENTES=
RDA_BATCH_IDS=

RDA_AUTH_SECRET=


# ==========================================================
# RCA — Relatorio de Coletas e Analises
# ==========================================================
RCA_PG_HOST=
RCA_PG_PORT=
RCA_PG_DATABASE=
RCA_PG_USER=
RCA_PG_PASSWORD=
RCA_PORT=
RCA_CORS_ORIGIN=


# ==========================================================
# FLEET INTELLIGENCE
# ==========================================================
APP_NAME=
APP_ENV=
DEBUG=

POSTGRES_HOST=
POSTGRES_PORT=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=

JWT_SECRET_KEY=
JWT_ALGORITHM=
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=

# -- SMTP prefixado FI_ (evita conflito com SMTP_* do Portal) --
FI_SMTP_HOST=
FI_SMTP_PORT=
FI_SMTP_USER=
FI_SMTP_PASSWORD=
FI_SMTP_FROM_NAME=
FI_SMTP_FROM_EMAIL=
FI_ADMIN_EMAIL=

FRONTEND_URL=
CORS_ORIGINS=


# ==========================================================
# CSC-DASHBOARD (sub-dashboard do Portal)
# ==========================================================
CSC_DB_HOST=
CSC_DB_PORT=
CSC_DB_NAME=
CSC_DB_USER=
CSC_DB_PASSWORD=
CSC_DB_HOST_PORT=
CSC_BACKEND_PORT=
CSC_FRONTEND_PORT=
CSC_BACKEND_URL=
CSC_UPLOAD_ALLOWED_EMAILS=


# ==========================================================
# DFA-DASHBOARD (sub-dashboard do Portal)
# ==========================================================
DFA_DB_HOST=
DFA_DB_PORT=
DFA_DB_NAME=
DFA_DB_USER=
DFA_DB_PASSWORD=
DFA_DB_HOST_PORT=
DFA_BACKEND_PORT=
DFA_FRONTEND_PORT=
DFA_BACKEND_URL=
DFA_UPLOAD_ALLOWED_EMAILS=


# ==========================================================
# PSI-DASHBOARD (sub-dashboard do Portal)
# ==========================================================
PSI_BACKEND_PORT=
PSI_FRONTEND_PORT=
PSI_BACKEND_URL=
PSI_UPLOAD_ALLOWED_EMAILS=


# ==========================================================
# WIRTGEN ALERT CENTER (sub-dashboard do Portal — read-only)
# ==========================================================
# Nao possui banco proprio: le direto do csc_veneza via DB_* (bloco Portal).
# Consulta layer_bronze.opc_machine_alerts + opc_equipment + public.localizacao_maquinas.
WAC_BACKEND_PORT=
WAC_FRONTEND_PORT=
WAC_BACKEND_URL=
# Opcionais (tem defaults sensatos no docker-compose):
# WAC_PGPOOL_MAX=10
# WAC_PG_STATEMENT_TIMEOUT=120000
